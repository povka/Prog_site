{
  "name": "asapaskaprog",
  "main": "src/worker.js",
  "compatibility_date": "2026-03-30",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "r2_buckets": [
    {
      "binding": "SITE_IMAGES",
      "bucket_name": "prog-site",
      "remote": true
    }
  ]
}